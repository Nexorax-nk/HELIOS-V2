# ─── Claude / AI ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model selection (override per-agent if needed)
HELIOS_REASONING_MODEL=claude-sonnet-4-5
HELIOS_ORACLE_MODEL=claude-opus-4-5

# ─── GitHub App ────────────────────────────────────────────
# Register at: https://github.com/settings/apps/new
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=./github-app.private-key.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# ─── HELIOS Server ─────────────────────────────────────────
HELIOS_SERVER_URL=http://localhost:8000
HELIOS_SECRET_TOKEN=your-internal-secret-here

# ─── ChromaDB (Foundry IQ) ──────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=helios_knowledge_base

# ─── Microsoft IQ (Optional — for real integration) ─────────
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=
# MS_GRAPH_TENANT_ID=

# ─── Feature Flags ──────────────────────────────────────────
# Set to true to enable streaming SSE output
HELIOS_STREAMING=true
# Set to true to use local ChromaDB (false = remote)
CHROMA_LOCAL=true
